# Lakebase PostgreSQL Connection
# Copy this to .env and fill in your values

# Option 1: Use DATABASE_URL (recommended - single variable)
DATABASE_URL='postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require'
# Example:
# DATABASE_URL='postgresql://daniel.liden%40databricks.com:YOUR_PASSWORD@ep-nameless-flower-d16ys9x1.database.us-west-2.cloud.databricks.com/databricks_postgres?sslmode=require'

# Option 2: Use individual PG* environment variables
# PGHOST='ep-nameless-flower-d16ys9x1.database.us-west-2.cloud.databricks.com'
# PGDATABASE='databricks_postgres'
# PGUSER='daniel.liden@databricks.com'
# PGSSLMODE='require'
# PGPASSWORD='your-password-or-oauth-token-here'

# How to get password:
#
# Option A: OAuth Token (expires in 1 hour, regenerate as needed)
#   databricks database generate-database-credential \
#     --request-id $(uuidgen) \
#     --json '{"instance_names": ["YOUR_INSTANCE_NAME"]}'
#
# Option B: Native Postgres Password (doesn't expire)
#   Create in Lakebase UI: Data -> Lakebase -> Roles -> Create Role
