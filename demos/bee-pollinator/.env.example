# Bee Pollinator Demo Configuration
# Copy this to .env and fill in your values

# ============================================
# Optional Settings
# ============================================

# USDA NASS API key (only needed to regenerate data snapshots)
# Get one at: https://quickstats.nass.usda.gov/api/
USDA_NASS_API_KEY=your_api_key_here

# Databricks host and token (for local CLI usage outside of a Databricks workspace)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your_token_here
